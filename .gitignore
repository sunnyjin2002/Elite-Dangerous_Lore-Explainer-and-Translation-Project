# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Local environment files
.env
.env.*
!.env.example

# Editor and OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# SQLite runtime data
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
!data/.gitkeep

# App-generated local data
/data/uploads/*
!/data/uploads/.gitkeep
/data/imports/*
!/data/imports/.gitkeep
